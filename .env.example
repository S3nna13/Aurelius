# Aurelius Backend Configuration

# Server
AURELIUS_VERSION=0.1.0
AURELIUS_LOG_LEVEL=info
AURELIUS_HOST=127.0.0.1
AURELIUS_PORT=8080
AURELIUS_RELOAD=false
AURELIUS_DEVICE=cpu
AURELIUS_DTYPE=bfloat16

# Authentication — both require this to be set
# AURELIUS_AUTH=false disables auth (not recommended for production)
AURELIUS_API_KEY=
AURELIUS_API_KEY_ENABLED=false
AURELIUS_API_KEYS_PATH=configs/api_keys.json

# Rate Limiting
AURELIUS_RATE_LIMIT_ENABLED=false
AURELIUS_RATE_LIMIT_RPS=60

# Redis
REDIS_URL=redis://localhost:6379/0

# Database
DATABASE_URL=sqlite:///data/aurelius.db
