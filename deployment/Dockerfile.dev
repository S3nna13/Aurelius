# syntax=docker/dockerfile:1
FROM python@sha256:46cb7cc2877e60fbd5e21a9ae6115c30ace7a077b9f8772da879e4590c18c2e3
WORKDIR /app

RUN pip install --no-cache-dir uv && \
    uv sync --dev

RUN useradd -r -s /bin/false aurelius && \
    chown -R aurelius:aurelius /app
USER aurelius

EXPOSE 8080

CMD ["uvicorn", "src.serving.api_server:app", "--host", "0.0.0.0", "--port", "8080", "--reload"]
