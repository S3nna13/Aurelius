# Middle BFF Configuration

# Server
MIDDLE_HOST=0.0.0.0
MIDDLE_PORT=3001
MIDDLE_LOG_LEVEL=info

# Upstream (Python API)
UPSTREAM_URL=http://127.0.0.1:8080

# Authentication — REQUIRED (middle fails to start without it)
AURELIUS_API_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# Redis (optional — gracefully degrades if unavailable)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_RPS=60
RATE_LIMIT_WINDOW_MS=60000
