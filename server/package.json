{
  "name": "aurelius-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && cp -r ../frontend/dist ./dist/public",
    "start": "node dist/main.js",
    "build:engine": "cd ../crates/data-engine && napi build --release --platform",
    "//postinstall": "npm run build:engine"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.1",
    "http-proxy-middleware": "^3.0.5",
    "pino": "^9.6.0",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.8.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2"
  }
}
